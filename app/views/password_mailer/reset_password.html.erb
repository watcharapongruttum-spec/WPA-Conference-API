<!DOCTYPE html>
<html>
  <body style="font-family: Arial, Helvetica, sans-serif; background:#f6f6f6; padding:20px;">
    
    <table width="100%" cellpadding="0" cellspacing="0">
      <tr>
        <td align="center">
          
          <table width="520" cellpadding="0" cellspacing="0" 
                 style="background:white; border-radius:8px; padding:24px; box-shadow:0 2px 6px rgba(0,0,0,0.1);">
            
            <!-- TITLE -->
            <tr>
              <td align="center">
                <h2 style="margin:0; color:#333;">
                  Reset Your Password
                </h2>
              </td>
            </tr>

            <!-- DESCRIPTION -->
            <tr>
              <td style="padding-top:16px; color:#555; font-size:14px;">
                You recently requested to reset your password.  
                Choose one of the options below to continue.
              </td>
            </tr>

            <!-- RESET BUTTON -->
            <tr>
              <td align="center" style="padding-top:24px;">
                <a href="<%= reset_url %>"
                  style="display:inline-block;
                          padding:12px 20px;
                          background:#4CAF50;
                          color:white;
                          text-decoration:none;
                          border-radius:6px;
                          font-weight:bold;">
                  Reset Password
                </a>
              </td>
            </tr>

            <!-- TOKEN -->
            <tr>
              <td style="padding-top:24px; font-size:13px; color:#666;">
                If the buttons do not work, copy this token:
              </td>
            </tr>

            <tr>
              <td align="center" style="padding-top:8px;">
                <div style="background:#f0f0f0;
                            padding:10px;
                            border-radius:6px;
                            font-weight:bold;
                            font-size:16px;
                            word-break:break-all;">
                  <%= token %>
                </div>
              </td>
            </tr>

            <!-- WARNING -->
            <tr>
              <td style="padding-top:24px; font-size:12px; color:#999;">
                If you did not request a password reset,  
                you can safely ignore this email.
              </td>
            </tr>

          </table>

        </td>
      </tr>
    </table>

  </body>
</html>
